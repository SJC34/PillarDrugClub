# ============================================================
# Pharmacy Autopilot — Environment Variables
# Copy this file to .env and fill in all values before running
# NEVER commit .env to version control
# ============================================================

# ─── Database ─────────────────────────────────────────────
# AWS RDS PostgreSQL connection string
DATABASE_URL=postgresql://username:password@your-rds-endpoint.amazonaws.com:5432/pharmacyautopilot

# ─── Session / Security ───────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string-at-least-64-chars
ENCRYPTION_KEY=change-this-to-a-32-byte-hex-key-for-aes-256-encryption

# ─── Square (Payment Processing) ──────────────────────────
# From: https://developer.squareup.com/apps
SQUARE_ACCESS_TOKEN=EAAAl...
SQUARE_LOCATION_ID=L...
SQUARE_PLAN_VARIATION_ID=...   # The plan variation ID from your Square subscription plan
SQUARE_WEBHOOK_SIGNATURE_KEY=...
SQUARE_WEBHOOK_URL=https://pharmacyautopilot.com/api/webhooks/square

# Frontend Square keys (must be prefixed with VITE_)
VITE_SQUARE_APP_ID=sq0idp-...
VITE_SQUARE_LOCATION_ID=L...
VITE_SQUARE_SANDBOX=false   # Set to "true" for sandbox, "false" for production

# ─── Google OAuth ─────────────────────────────────────────
# From: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Resend (Transactional Email) ─────────────────────────
# From: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ─── Twilio (SMS) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ─── Twitter / X ──────────────────────────────────────────
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_TOKEN_SECRET=...

# ─── Mailchimp (optional) ─────────────────────────────────
MAILCHIMP_API_KEY=...
MAILCHIMP_AUDIENCE_ID=...
MAILCHIMP_SERVER_PREFIX=us1

# ─── Application ──────────────────────────────────────────
NODE_ENV=production
PORT=5000
CUSTOM_DOMAIN=pharmacyautopilot.com

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# LLM Provider (openai or ollama)
LLM_PROVIDER=openai
EMBEDDINGS_PROVIDER=openai

# Whitelisted Domains (comma-separated)
WHITELIST_DOMAINS=dailymed.nlm.nih.gov,fda.gov,cdc.gov,nih.gov,uspreventiveservicestaskforce.org,ahrq.gov,idsociety.org,acog.org,diabetes.org

# Chunking Configuration
CHUNK_MIN_TOKENS=400
CHUNK_MAX_TOKENS=900
CHUNK_OVERLAP_TOKENS=100

# Retrieval Configuration
MIN_RETRIEVED_CHUNKS=3
FRESHNESS_YEARS=5
DEFAULT_K_NEIGHBORS=10

# Generation Configuration
MIN_CITATIONS=5
MAX_GENERATION_TIME_SECONDS=300

# Database
DATABASE_PATH=./data/medical_blog.db

# Vector Store
VECTOR_STORE_TYPE=faiss
VECTOR_STORE_PATH=./data/vectors

# Server
API_HOST=0.0.0.0
API_PORT=8001
